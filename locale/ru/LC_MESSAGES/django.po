msgstr "С вами свяжутся и согласуют удобное время"

msgid "Hayvoningiz klinikada ko‘rikdan o‘tkaziladi"
msgstr "Ваш питомец пройдёт осмотр в клинике"

msgid "Klinikamiz xizmatlari"
msgstr "Услуги нашей клиники"

msgid "Hayvonlar salomatligi uchun zarur bo‘lgan asosiy veterinariya, laboratoriya va diagnostika xizmatlari."
msgstr "Основные ветеринарные, лабораторные и диагностические услуги, необходимые для здоровья животных."

msgid "Hayvonning umumiy holati tekshiriladi va davolash yo‘nalishi belgilanadi."
msgstr "Проверяется общее состояние животного и определяется направление лечения."

msgid "Tahlil so‘rovlari laboratoriya xodimlari tomonidan qayta ishlanadi."
msgstr "Запросы на анализы обрабатываются сотрудниками лаборатории."

msgid "Natijalar asosida diagnostik xulosa va tavsiyalar tayyorlanadi."
msgstr "На основе результатов готовятся диагностическое заключение и рекомендации."

msgid "Barcha xizmatlarni ko‘rish"
msgstr "Посмотреть все услуги"

msgid "Afzalliklar"
msgstr "Преимущества"

msgid "Nega VetClinic’ni tanlashadi?"
msgstr "Почему выбирают VetClinic?"

msgid "VetClinic hayvonlar salomatligiga mas’uliyat bilan yondashadi. Biz mijozlarga qulay, tezkor va ishonchli veterinariya xizmatlarini taqdim etishga harakat qilamiz."
msgstr "VetClinic ответственно подходит к здоровью животных. Мы стремимся предоставлять клиентам удобные, быстрые и надёжные ветеринарные услуги."

msgid "Tajribali veterinarlar hayvoningiz holatini diqqat bilan tekshiradi."
msgstr "Опытные ветеринары внимательно проверяют состояние вашего питомца."

msgid "Laboratoriya tahlillari va diagnostika xizmatlari mavjud."
msgstr "Доступны лабораторные анализы и диагностические услуги."

msgid "Har bir hayvonga mehr va individual yondashuv asosida xizmat ko‘rsatiladi."
msgstr "Каждому животному предоставляется заботливый и индивидуальный подход."

msgid "Bizning afzalliklarimiz"
msgstr "Наши преимущества"

msgid "Qulay murojaat"
msgstr "Удобное обращение"

msgid "Telegram bot orqali tez va oson ariza yuborish mumkin."
msgstr "Через Telegram-бот можно быстро и легко отправить заявку."

msgid "Malakali mutaxassislar"
msgstr "Квалифицированные специалисты"

msgid "Hayvonlar salomatligi bo‘yicha tajribali xodimlar xizmat ko‘rsatadi."
msgstr "Услуги оказывают опытные сотрудники в области здоровья животных."

msgid "Zamonaviy yondashuv"
msgstr "Современный подход"

msgid "Ko‘rik, tahlil va diagnostika jarayonlari tartibli olib boriladi."
msgstr "Процессы осмотра, анализа и диагностики ведутся упорядоченно."

msgid "Ishonchli xizmat"
msgstr "Надёжный сервис"

msgid "Mijozlarga tushunarli, qulay va sifatli xizmat ko‘rsatish maqsad qilingan."
msgstr "Наша цель — понятное, удобное и качественное обслуживание клиентов."

msgid "Foydali ma’lumotlar"
msgstr "Полезная информация"

msgid "Hayvonlar parvarishi, emlash, profilaktika va klinika yangiliklari haqida."
msgstr "О уходе за животными, вакцинации, профилактике и новостях клиники."

msgid "Laboratoriya tahlillari nima uchun kerak?"
msgstr "Зачем нужны лабораторные анализы?"

msgid "Tahlillar kasallikni aniqlash va davolash yo‘nalishini tanlashda yordam beradi."
msgstr "Анализы помогают выявить заболевание и выбрать направление лечения."

msgid "Hayvonlarni vaqtida emlash muhim"
msgstr "Важно вовремя вакцинировать животных"

msgid "Profilaktik emlashlar ko‘plab xavfli kasalliklarning oldini oladi."
msgstr "Профилактические прививки предотвращают многие опасные заболевания."

msgid "Uy hayvonlarini parvarish qilish"
msgstr "Уход за домашними животными"

msgid "To‘g‘ri ovqatlantirish va muntazam ko‘rik sog‘liqni saqlashga yordam beradi."
msgstr "Правильное питание и регулярный осмотр помогают сохранить здоровье."

msgid "Yangiliklarni ko‘rish"
msgstr "Посмотреть новости"

msgid "Ariza yuborish uchun Telegram botga o‘ting. Klinikamiz xodimlari arizangizni ko‘rib chiqib, siz bilan bog‘lanadi."
msgstr "Чтобы отправить заявку, перейдите в Telegram-бот. Сотрудники клиники рассмотрят заявку и свяжутся с вами."

msgid "Telegram botga o‘tish"
msgstr "Перейти в Telegram-бот"
